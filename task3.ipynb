    {
      "cell_type": "markdown",
      "source": [
        "## Creating Dataset XY\n",
        "\n",
        "Taking each row in the BED file (ATAC-seq), extract the start and end positions, and cut the corresponding sequence from the FASTA file (genome)."
      ],
      "metadata": {
        "id": "07zRDv7l42b4"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Load file BED\n",
        "df_bed = pd.read_csv('ENCFF246KRE.bed', sep='\\t', header=None,\n",
        "                     names=['chrom', 'start', 'end', 'name', 'score', 'strand', 'signal', 'p', 'q', 'peak'])\n",
        "\n",
        "train_chroms = ['chr8']\n",
        "val_chroms = ['chr19']\n",
        "test_region = ['chr10']\n",
        "\n",
        "\n",
        "# Training: chr8\n",
        "df_train = df_bed[df_bed['chrom'].isin(train_chroms)].drop_duplicates(subset=['start', 'end'])\n",
        "\n",
        "# Validation: chr19\n",
        "df_val = df_bed[df_bed['chrom'].isin(val_chroms)].drop_duplicates(subset=['start', 'end'])\n",
        "\n",
        "# Testing: chr10 (intereting area)\n",
        "df_test = df_bed[df_bed['chrom'].isin(test_region)].drop_duplicates(subset=['start', 'end'])\n",
        "\n",
        "# Generation of sequences (X) and labels (Y)\n",
        "\n",
        "def prepare_genomic_data(df, genome_dict, window_size=512):\n",
        "    X_sequences = []  #  ADN\n",
        "    Y_signals = []    # Target: Intensidad de la señal\n",
        "\n",
        "    for i, row in df.iterrows():\n",
        "        chrom = row['chrom']\n",
        "\n",
        "        # Calculate the center and the window based on start and end.\n",
        "        center = (row['start'] + row['end']) // 2\n",
        "        start = center - (window_size // 2)\n",
        "        end = start + window_size\n",
        "\n",
        "\n",
        "        sequence = str(genome_dict[chrom][start:end].seq).upper()\n",
        "\n",
        "        if len(sequence) == window_size:\n",
        "            X_sequences.append(sequence)\n",
        "            Y_signals.append(row['signal'])\n",
        "\n",
        "    return X_sequences, Y_signals\n",
        "\n",
        "# window_size=512` because it is the standard for DNABERT-6\n",
        "# Traing Set\n",
        "X_train, Y_train = prepare_genomic_data(df_train, genome, window_size=512)\n",
        "# Validation Set\n",
        "X_val, Y_val = prepare_genomic_data(df_val, genome, window_size=512)\n",
        "# Testing Set de Testing (Cromosoma 10)\n",
        "X_test, Y_test_real = prepare_genomic_data(df_test, genome, window_size=512)\n",
        "\n",
        "# Verification\n",
        "print(f\"✅ Procesamiento completado:\")\n",
        "print(f\"- Training (Chr8):   {len(X_train)} secuencias | {len(Y_train)} labels\")\n",
        "print(f\"- Validation (Chr19): {len(X_val)} secuencias | {len(Y_val)} labels\")\n",
        "print(f\"- Testing (Chr10):    {len(X_test)} secuencias | {len(Y_test_real)} labels\")\n"
      ],
